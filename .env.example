# ============================================================
# NAGAKI AGENT - Variables de Entorno
# ============================================================
# Copiar este archivo a .env y configurar los valores reales.

# ------------------------------------------------------------
# OPENAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# ------------------------------------------------------------
# INMOBIGRAMA API (Consulta de Inmuebles)
# ------------------------------------------------------------
# API para consultar propiedades inmobiliarias
# Documentación: https://api.inmobigrama.com
INMOBIGRAMA_API_URL=https://api.inmobigrama.com
X-API-Key=your-inmobigrama-api-key

# ------------------------------------------------------------
# EVOLUTION API (WhatsApp)
# ------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
EVOLUTION_WEBHOOK_PORT=3000

# ------------------------------------------------------------
# REDIS (COMPARTIDO ENTRE VOZ + WHATSAPP + QUALIFICATION)
# ------------------------------------------------------------
# Recomendado: DB 0 para qualification
REDIS_URL=redis://redis:6379/0

# Timeout (ms) para leer snapshot de calificación antes de fail-open
QUAL_SNAPSHOT_TIMEOUT_MS=250

# Configuración del buffer de mensajes
# Tiempo máximo de espera para acumular mensajes fragmentados (segundos)
REDIS_MESSAGE_BUFFER_TIMEOUT=30
# TTL del buffer (debe ser mayor que el timeout)
REDIS_MESSAGE_BUFFER_TTL=90

# Opcional recomendado: DB separada para cola WhatsApp (evita colisiones)
WHATSAPP_QUEUE_REDIS_URL=redis://redis:6379/1

# ------------------------------------------------------------
# LANGGRAPH (PostgreSQL Checkpoint)
# ------------------------------------------------------------
CHECKPOINTER_TYPE=postgres
POSTGRES_CONNECTION_STRING=postgresql://user:pass@postgres:5432/nagaki

# ------------------------------------------------------------
# LEADS API (sync en cambios de stage interested/qualified)
# ------------------------------------------------------------
LEADS_API_BASE_URL=https://your-leads-api.com
LEADS_API_KEY=your-leads-api-key
LEADS_API_UPSERT_ENDPOINT=/api/v1/leads
LEAD_SYNC_DB_PATH=/data/lead_sync.db

# ------------------------------------------------------------
# VAPI (Opcional - para voz)
# ------------------------------------------------------------
VAPI_API_KEY=your-vapi-api-key
