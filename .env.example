# ============================================================
# NAGAKI AGENT - Variables de Entorno
# ============================================================
# Copiar este archivo a .env y configurar los valores reales.

# ------------------------------------------------------------
# OPENAI
# ------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# ------------------------------------------------------------
# INMOBIGRAMA API (Consulta de Inmuebles)
# ------------------------------------------------------------
# API para consultar propiedades inmobiliarias
# Documentación: https://api.inmobigrama.com
INMOBIGRAMA_API_URL=https://api.inmobigrama.com
X-API-Key=your-inmobigrama-api-key

# ------------------------------------------------------------
# EVOLUTION API (WhatsApp)
# ------------------------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=your-instance-name
EVOLUTION_WEBHOOK_PORT=3000

# ------------------------------------------------------------
# REDIS CLOUD
# ------------------------------------------------------------
# Formato de URL para Redis Cloud:
# redis://[username]:[password]@[host]:[port]
#
# Ejemplo Redis Labs/Cloud:
# redis://default:mypassword@redis-11905.c14.us-east-1-3.ec2.cloud.redislabs.com:11905
#
# Para conexión con SSL (recomendado en producción):
# rediss://default:mypassword@redis-11905.c14.us-east-1-3.ec2.cloud.redislabs.com:11905
#
REDIS_URL=redis://default:your-redis-password@redis-host.cloud.redislabs.com:11905

# Configuración del buffer de mensajes
# Tiempo máximo de espera para acumular mensajes fragmentados (segundos)
REDIS_MESSAGE_BUFFER_TIMEOUT=30
# TTL del buffer (debe ser mayor que el timeout)
REDIS_MESSAGE_BUFFER_TTL=90

# ------------------------------------------------------------
# LANGGRAPH (PostgreSQL Checkpoint)
# ------------------------------------------------------------
POSTGRES_CONNECTION_STRING=postgresql://user:password@host:port/database

# ------------------------------------------------------------
# VAPI (Opcional - para voz)
# ------------------------------------------------------------
VAPI_API_KEY=your-vapi-api-key
